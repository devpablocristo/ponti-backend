FROM golang:1.24

# Instalar herramientas y dependencias básicas para Go y entorno dev
RUN apt-get update && \
    apt-get install -y --no-install-recommends docker.io git zsh tzdata curl tree xclip && \
    rm -rf /var/lib/apt/lists/* && \
    go install github.com/go-delve/delve/cmd/dlv@latest && \
    go install golang.org/x/tools/gopls@latest && \
    go install github.com/cweill/gotests/gotests@v1.6.0 && \
    go install github.com/fatih/gomodifytags@v1.17.0 && \
    go install github.com/josharian/impl@v1.4.0 && \
    go install github.com/haya14busa/goplay/cmd/goplay@v1.0.0 && \
    go install honnef.co/go/tools/cmd/staticcheck@latest

# Configurar zona horaria
ENV TZ=America/Argentina/Buenos_Aires
RUN ln -fs /usr/share/zoneinfo/America/Argentina/Buenos_Aires /etc/localtime && \
    dpkg-reconfigure -f noninteractive tzdata

ENV PATH="/root/go/bin:${PATH}"

# Directorio de trabajo raíz del repo
WORKDIR /app

# Copiar TODO el repo (incluyendo migraciones)
COPY . .

# Copia la carpeta de migraciones al contenedor
# COPY projects/ponti-api/migrations /app/migrations

# Opcional: mostrar los archivos copiados (debug)
# RUN ls -lh /app/migrations

# Instalar dependencias Go del proyecto principal y de pkg
WORKDIR /app/projects/ponti-api
RUN go mod download && go mod verify

WORKDIR /app/pkg
RUN go mod download && go mod verify

WORKDIR /app

# Crear tmp con permisos para Go y otras herramientas
RUN mkdir -p /app/tmp && chmod -R 775 /app/tmp

# Crear usuario vscode para dev y dejar Oh My Zsh configurado
RUN useradd -m -s /usr/bin/zsh vscode

USER vscode
WORKDIR /home/vscode
RUN curl -Lo install.sh https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh && \
    RUNZSH=no sh install.sh && \
    rm install.sh && \
    cp /home/vscode/.oh-my-zsh/templates/zshrc.zsh-template /home/vscode/.zshrc

WORKDIR /app

EXPOSE 8080 2345

CMD ["tail", "-f", "/dev/null"]
