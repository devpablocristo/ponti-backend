# General
APP_NAME=ponti-api
APP_VERSION=1.0
APP_ENV=dev
APP_MAX_RETRIES=5
APP_ROOT=/app

# API
API_VERSION=v1

# Http server
HTTP_SERVER_NAME=http-server
HTTP_SERVER_HOST=localhost
HTTP_SERVER_PORT=8080

# Delve
DEBUGGER_PORT=2345

# Gorm
DB_TYPE=postgres
DB_USER=admin
DB_PASSWORD=admin
DB_HOST=ponti-db
DB_NAME=ponti_api_db
DB_SSL_MODE=disable
DB_PORT=5432

X_API_KEY=abc123secreta

# PgAdmin Configuration
PGADMIN_PORT=8083
PGADMIN_TARGET_PORT=80
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin
