# General Application Configuration
APP_NAME=ponti-api
APP_VERSION=1.0
APP_ENV=dev
APP_MAX_RETRIES=5
APP_ROOT=/app
API_VERSION=v1

# Http Router Configuration
HTTP_SERVER_NAME=http-server
HTTP_SERVER_HOST=localhost
HTTP_SERVER_PORT=8080

# Delve Configuration
DELVE_PORT=2345

# JWT Configuration
JWT_SECRET_KEY=secret

SSL_MODE=disable

GORM_TYPE=postgres
GORM_HOST=ponti-db
GORM_PORT=5432
GORM_USER=admin
GORM_PASSWORD=admin
GORM_NAME=ponti_api_db

# PostgreSQL Configuration
POSTGRES_HOST=ponti-db
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=ponti_api_db

# PgAdmin Configuration
PGADMIN_PORT=8083
PGADMIN_TARGET_PORT=80
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin
