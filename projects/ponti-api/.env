# Delve
DEBUGGER_PORT=2345

# Postgres Database
# DB_TYPE=postgres
# DB_USER=admin
# DB_PASSWORD=admin
# DB_HOST=127.0.0.1
# DB_NAME=ponti_api_db
# DB_SSL_MODE=disable
# DB_PORT=5432

DB_TYPE=postgres
DB_USER=soalen-db-v3
DB_PASSWORD=Soalen*25.
DB_HOST=34.176.31.249
DB_NAME=ponti_api_db
