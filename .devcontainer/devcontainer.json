{
  "name": "Ponti API Dev Container",
  "dockerComposeFile": ["../projects/ponti-api/docker-compose.yml"],
  "service": "ponti-api",
  "workspaceFolder": "/app",
  "forwardPorts": [2345, 8080],
  "customizations": {
    "vscode": {
      "extensions": [
        "adamvoss.vscode-languagetool",
        "adpyke.vscode-sql-formatter",
        "ahmadawais.shades-of-purple",
        "alefragnani.delphi-themes",
        "ancientlord.nightowl-theme",
        "andrsdc.base16-themes",
        "antfu.theme-vitesse",
        "atariq11700.debugpy-old",
        "ceciljacob.code-plus-theme",
        "daylerees.rainglow",
        "dbaeumer.vscode-eslint",
        "docker.docker",
        "donjayamanne.githistory",
        "eamodio.gitlens",
        "ekelley.midnight-synth",
        "esbenp.prettier-vscode",
        "fnando.linter",
        "formulahendry.code-runner",
        "github.codespaces",
        "github.copilot",
        "github.copilot-chat",
        "github.github-vscode-theme",
        "github.remotehub",
        "github.vscode-pull-request-github",
        "golang.go",
        "gruntfuggly.todo-tree",
        "henriiik.docker-linter",
        "hoovercj.vscode-settings-cycler",
        "ionutvmi.path-autocomplete",
        "irongeek.vscode-env",
        "jakebathman.mysql-syntax",
        "juanmnl.vscode-theme-1984",
        "mechatroner.rainbow-csv",
        "mrpbennett.atlantic-night",
        "ms-azuretools.vscode-containers",
        "ms-azuretools.vscode-docker",
        "ms-dotnettools.vscode-dotnet-runtime",
        "ms-python.debugpy",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers",
        "ms-toolsai.vscode-jupyter-cell-tags",
        "ms-toolsai.vscode-jupyter-powertoys",
        "ms-toolsai.vscode-jupyter-slideshow",
        "ms-vscode-remote.remote-containers",
        "ms-vscode-remote.remote-ssh",
        "ms-vscode-remote.remote-ssh-edit",
        "ms-vscode-remote.vscode-remote-extensionpack",
        "ms-vscode.azure-repos",
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.cpptools-themes",
        "ms-vscode.makefile-tools",
        "ms-vscode.remote-explorer",
        "ms-vscode.remote-repositories",
        "ms-vscode.remote-server",
        "ms-vscode.wordcount",
        "oderwat.indent-rainbow",
        "premparihar.gotestexplorer",
        "rdebugger.r-debugger",
        "re7rix2.50-shades-of-purple",
        "rebornix.toggle",
        "reditorsupport.r",
        "reditorsupport.r-syntax",
        "sldobri.bunker",
        "tamasfe.even-better-toml",
        "tomoki1207.pdf",
        "tyriar.vscode-terminal-here",
        "ustymukhman.matrix-theme",
        "viphakorn.mix-night-blue",
        "visualstudioexptteam.intellicode-api-usage-examples",
        "visualstudioexptteam.vscodeintellicode",
        "visualstudioexptteam.vscodeintellicode-completions",
        "visualstudioexptteam.vscodeintellicode-insiders",
        "vscode-icons-team.vscode-icons",
        "yile-ou.paddy-color-theme",
        "yzane.markdown-pdf",
        "zxh404.vscode-proto3"
      ]
    }
  },
  "remoteEnv": {
    "GO111MODULE": "on"
  },
  "settings": {
    "go.useLanguageServer": true
  },
  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt=seccomp=unconfined",
    "--volume=/var/run/docker.sock:/var/run/docker.sock"
  ],
  "postStartCommand": "go mod download"
}
