# App
SERVICE_NAME=ponti-api
SERVICE_VERSION=1.0
SERVICE_MAX_RETRIES=5
TZ=UTC

# Heather
X_API_KEY=abc123secreta

# API
API_VERSION=v1

# Http server
HTTP_SERVER_NAME=http-server
HTTP_SERVER_HOST=localhost
HTTP_SERVER_PORT=8080

# Delve
DEBUGGER_PORT=2345

# Postgres Database
DB_TYPE=postgres
DB_USER=admin
DB_PASSWORD=admin
DB_HOST=127.0.0.1
DB_NAME=ponti_api_db
DB_SSL_MODE=disable
DB_PORT=5432


# Golang Migrations
MIGRATIONS_DIR=file://migrations

# Words Suggester
WORDS_SUGGESTER_LIMIT=100
WORDS_SUGGESTER_THRESHOLD=0.3

REPORT_SCHEMA=v4_report
