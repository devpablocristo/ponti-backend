# Ponti Backend - Example env
#
# Uso:
# cp .env.example .env
#
# Nota:
# Si tenes PostgreSQL del sistema en 5432, usa DB_PORT=5433 y recrea compose.
# Si vas a bajar modulos privados de GitHub dentro de Docker, defini GO_MODULES_TOKEN.

# App
SERVICE_NAME=ponti-api
SERVICE_VERSION=1.0
SERVICE_MAX_RETRIES=5

# Private Go modules
GO_MODULES_TOKEN=

# Security
X_API_KEY=local-dev-api-key
# Local: por defecto NO validar contra Identity Platform (modo dev local).
# En dev/staging/prod (Cloud Run), setear AUTH_ENABLED=true y completar IDENTITY_*.
AUTH_ENABLED=false
IDENTITY_PROJECT_ID=
IDENTITY_ISSUER=
IDENTITY_AUDIENCE=
IDENTITY_JWKS_URL=https://www.googleapis.com/service_accounts/v1/jwk/securetoken@system.gserviceaccount.com
IDENTITY_JWKS_CACHE_TTL_SECONDS=300
TENANT_HEADER_NAME=X-Tenant-Id
AUTH_AUTO_PROVISION_MEMBERSHIP=true
AUTH_DEFAULT_TENANT_NAME=default
AUTH_DEFAULT_ROLE_NAME=admin

# API
API_VERSION=v1

# HTTP server
HTTP_SERVER_NAME=http-server
HTTP_SERVER_HOST=localhost
HTTP_SERVER_PORT=8080

# Database
DB_TYPE=postgres
DB_USER=admin
DB_PASSWORD=admin
DB_HOST=127.0.0.1
DB_NAME=new_ponti_db_dev
DB_SSL_MODE=disable
DB_PORT=5432

# PROD data source for local DB reset (read-only dump source)
DB_NAME_PROD=new_ponti_db_prod
DB_USER_PROD=soalen-db-v3
CLOUDSQL_PROJECT_PROD=new-ponti-dev
DB_INSTANCE_NAME_PROD=new-ponti-db-dev
SRC_INSTANCE_PROJECT=new-ponti-dev
SRC_INSTANCE_REGION=us-central1
SRC_INSTANCE_NAME=new-ponti-db-dev
SRC_PASS_SECRET_PROJECT=new-ponti-dev
SRC_PASS_SECRET_NAME=db-password-dev

# Migrations
MIGRATIONS_DIR=file://migrations_v4

# Words suggester
WORDS_SUGGESTER_LIMIT=100
WORDS_SUGGESTER_THRESHOLD=0.3

# AI — Companion + Nexus (axis/)
# Companion es el agente IA horizontal; reemplaza ponti-ai (deprecated).
# Si ponti-api corre en Docker y axis-companion en otro compose con puerto publicado,
# usar host.docker.internal (ver docker-compose extra_hosts), NO http://localhost:18085.
#
# El secret + issuer + audience deben coincidir con lo que Companion espera
# (ver axis/docker-compose.yml: COMPANION_INTERNAL_JWT_*). En prod inyectar
# desde GCP Secret Manager.
COMPANION_BASE_URL=http://localhost:18085
COMPANION_INTERNAL_JWT_SECRET=axis-dev-internal-jwt-secret-change-me
COMPANION_INTERNAL_JWT_ISSUER=axis-bff
COMPANION_INTERNAL_JWT_AUDIENCE=companion
COMPANION_INTERNAL_JWT_TTL_SEC=300
COMPANION_TIMEOUT_MS=30000
COMPANION_MAX_RETRIES=2

# Nexus (motor de decisiones) — opcional en MVP solo-chat. Si NEXUS_BASE_URL
# está vacío, el binary arranca sin cliente Nexus (los gating checks se saltean).
NEXUS_BASE_URL=http://localhost:18084
NEXUS_INTERNAL_JWT_SECRET=axis-dev-internal-jwt-secret-change-me
NEXUS_INTERNAL_JWT_ISSUER=axis-bff
NEXUS_INTERNAL_JWT_AUDIENCE=nexus
NEXUS_INTERNAL_JWT_TTL_SEC=300
NEXUS_TIMEOUT_MS=10000
NEXUS_MAX_RETRIES=2

# Nexus Review (business insights / approvals). Si ponti-api corre en Docker,
# usar host.docker.internal igual que NEXUS_BASE_URL. La key debe coincidir con
# axis/.env:NEXUS_PONTI_API_KEY y con el service account `ponti` registrado en
# axis/docker-compose.yml:NEXUS_API_KEYS.
REVIEW_URL=http://localhost:18084
REVIEW_API_KEY=nexus-ponti-dev-key
REVIEW_SYNC_COOLDOWN_SEC=60
