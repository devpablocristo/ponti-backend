# Ponti Backend - Example env
#
# Uso:
# cp .env.example .env
#
# Nota:
# Si tenes PostgreSQL del sistema en 5432, usa DB_PORT=5433 y recrea compose.
# Si vas a bajar modulos privados de GitHub dentro de Docker, defini GO_MODULES_TOKEN.

# App
SERVICE_NAME=ponti-api
SERVICE_VERSION=1.0
SERVICE_MAX_RETRIES=5

# Private Go modules
GO_MODULES_TOKEN=

# Security
X_API_KEY=local-dev-api-key
# Local: por defecto NO validar contra Identity Platform (modo dev local).
# En dev/staging/prod (Cloud Run), setear AUTH_ENABLED=true y completar IDENTITY_*.
AUTH_ENABLED=false
IDENTITY_PROJECT_ID=
IDENTITY_ISSUER=
IDENTITY_AUDIENCE=
IDENTITY_JWKS_URL=https://www.googleapis.com/service_accounts/v1/jwk/securetoken@system.gserviceaccount.com
IDENTITY_JWKS_CACHE_TTL_SECONDS=300
TENANT_HEADER_NAME=X-Tenant-Id
# T1.a (seguridad): auto-provisioning de membership DESACTIVADO por defecto.
# En true, cualquier JWT válido sin membership se auto-onboardea al tenant
# AUTH_DEFAULT_TENANT_NAME con AUTH_DEFAULT_ROLE_NAME (NUNCA usar "admin" acá).
AUTH_AUTO_PROVISION_MEMBERSHIP=false
AUTH_DEFAULT_TENANT_NAME=default
AUTH_DEFAULT_ROLE_NAME=viewer
# T1.b (seguridad): idp_sub (lista separada por comas) de los operadores de
# plataforma. Solo ellos pueden crear tenants y gestionar memberships
# cross-tenant vía /admin. Vacío = nadie (esas operaciones quedan cerradas).
AUTH_PLATFORM_ADMIN_SUBJECTS=

# API
API_VERSION=v1

# HTTP server
HTTP_SERVER_NAME=http-server
HTTP_SERVER_HOST=localhost
HTTP_SERVER_PORT=8080

# Database
DB_TYPE=postgres
DB_USER=admin
DB_PASSWORD=admin
DB_HOST=127.0.0.1
DB_NAME=new_ponti_db_dev
DB_SSL_MODE=disable
DB_PORT=5432

# Migrations
MIGRATIONS_DIR=file://migrations_v4

# Words suggester
WORDS_SUGGESTER_LIMIT=100
WORDS_SUGGESTER_THRESHOLD=0.3

# AI Copilot service.
# Axis es el provider local por defecto. AI_SERVICE_* queda como fallback legacy.
AI_SERVICE_URL=http://localhost:8090
AI_SERVICE_KEY=local-dev-ai-service-key
AI_SERVICE_TIMEOUT_MS=5000
AI_PROVIDER=axis
AI_AXIS_ENABLED=true
# En Docker local, Ponti API llega al Axis Companion publicado en el host.
# Si corres Ponti API fuera de Docker, usar http://localhost:18085.
AXIS_COMPANION_BASE_URL=http://host.docker.internal:18085
AXIS_COMPANION_API_KEY=local-dev-companion-api-key
AXIS_COMPANION_TIMEOUT_MS=45000
AXIS_PRODUCT_SURFACE=ponti
PONTI_AXIS_API_KEY=local-dev-ponti-axis-api-key
# Insight ponti.stock.low: umbral per-tenant via business parameter
# ai.insights.low_stock_threshold_units; el env es solo fallback.
AI_INSIGHT_LOW_STOCK_ENABLED=false
AI_INSIGHT_LOW_STOCK_THRESHOLD=0

# Nexus Governance (cliente directo de Ponti core).
NEXUS_BASE_URL=http://localhost:18084
NEXUS_API_KEY=local-dev-nexus-api-key
NEXUS_TIMEOUT_MS=30000
# Token compartido con Nexus para verificar HMAC de callbacks (X-Nexus-Callback-Signature).
NEXUS_CALLBACK_TOKEN=
# Secreto opcional para firmar attestations de ejecución (Ola B).
NEXUS_ATTESTATION_HMAC_SECRET=
# Writes gobernados por IA (Ola B); el executor queda no-op hasta activarlo.
AI_GOVERNED_WRITES_ENABLED=false
# Verificación criptográfica de evidencia/attestations de Nexus (Ola B).
GOVERNANCE_VERIFY_NEXUS=false

# Token para acceder a los módulos privados de GitHub
GO_MODULES_TOKEN=
