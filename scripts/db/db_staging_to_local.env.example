# db_staging_to_local.env - Credenciales y vars para scripts/db/db_staging_to_local.sh
# Origen: new_ponti_db_staging (STAGING)
#
# cp scripts/db/db_staging_to_local.env.example scripts/db/db_staging_to_local.env
# Editar db_staging_to_local.env. No commitear db_staging_to_local.env.

# -------------------------
# DESTINO (LOCAL)
# -------------------------
# Conexión a la DB local (destino del restore).
DST_DB_HOST=127.0.0.1
DST_DB_PORT=5433
DST_DB_USER=admin
DST_DB_PASSWORD=admin
DST_DB_NAME=new_ponti_db_main_local

# STG
DB_NAME_STG=new_ponti_db_staging
DB_USER_STG=soalen-db-v3
# Proyecto/instancia de Cloud SQL donde vive STAGING (si usas proxy).
# Setear estos valores en tu env local (NO hardcodear en el repo).
CLOUDSQL_PROJECT_STG=
DB_INSTANCE_NAME_STG=

# Conexión staging
USE_CLOUDSQL_PROXY=auto
SRC_USER=soalen-db-v3
SRC_PASS=
SRC_HOST=
SRC_PORT=5432
SRC_SSL=disable
SRC_DB=new_ponti_db_staging

# Alternativa (recomendada): si NO seteás SRC_PASS, el script intenta leer el password
# desde Secret Manager usando gcloud ADC.
# Defaults actuales:
#   SRC_PASS_SECRET_PROJECT=new-ponti-dev
#   SRC_PASS_SECRET_NAME=db-password-dev
SRC_PASS_SECRET_PROJECT=
SRC_PASS_SECRET_NAME=
